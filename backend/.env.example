# ============================================================
# Nestly API — copy this file to .env and fill REAL values
#   copy:  cp .env.example .env   (or duplicate manually on Windows)
# Never commit .env to Git.
# ============================================================

NODE_ENV=development
PORT=4000

# ---- Database (PostgreSQL) — use ONE of the two styles ----

# Style A: full connection string (recommended)
# Example: postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres?schema=public
# Prefer a dedicated DB: postgresql://postgres:YOUR_PASSWORD@localhost:5432/nestly?schema=public
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres?schema=public

# Style B: separate fields (used only if DATABASE_URL is empty / still YOUR_PASSWORD)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=YOUR_PASSWORD
# DB_NAME=postgres
# DB_SCHEMA=public
# DB_SSL=false

# ---- Auth ----
JWT_SECRET=CHANGE_ME_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- App ----
CORS_ORIGIN=*
DEFAULT_CITY=Hyderabad
